---
import SearchPanel from '../components/SearchPanel.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="搜索" description="搜索 Field Notes 中的文章、项目和页面。">
  <div class="container search-page" data-pagefind-ignore>
    <header>
      <p class="eyebrow">SEARCH</p>
      <h1>找到需要的内容</h1>
      <p>索引完全在浏览器本地查询，不会上传你的搜索关键词。</p>
    </header>
    <SearchPanel />
  </div>
</BaseLayout>

<style>
  .search-page { padding-block: clamp(72px, 10vw, 120px) 120px; }
  header { max-width: 860px; margin: 0 auto 36px; }
  h1 { margin: 0; font-size: clamp(3rem, 8vw, 6rem); letter-spacing: -0.07em; line-height: 1; }
  header > p:last-child { max-width: 590px; margin: 20px 0 0; color: var(--muted); font-size: 1.08rem; }
</style>

