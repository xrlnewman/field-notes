---
import { getCollection } from 'astro:content';

import ProjectGallery from '../../components/ProjectGallery.astro';
import SectionHeading from '../../components/SectionHeading.astro';
import { isVisibleEntry, sortByPublishedAt } from '../../lib/content';
import { projectCategories } from '../../lib/projects';
import BaseLayout from '../../layouts/BaseLayout.astro';

const projects = sortByPublishedAt(
  (await getCollection('projects')).filter((entry) => isVisibleEntry(entry, import.meta.env.PROD)),
);
const categoryDescriptions = {
  网站产品: '从内容结构、体验设计到稳定发布的完整网站交付。',
  业务系统: '围绕真实业务流程构建可维护、可追踪的管理系统。',
  开发工具: '把重复工作沉淀为更顺手、更可靠的工程工具。',
  数据与搜索: '让复杂数据更快被检索、理解并转化为业务判断。',
  'AI 自动化': '将模型能力接入明确流程，减少重复操作和等待。',
} satisfies Record<(typeof projectCategories)[number], string>;
---

<BaseLayout title="项目作品" description="已经完成源码整理和安全检查的产品与工具，每个项目都可以查看实现过程和 GitHub 源码。">
  <div class="container page-shell" data-project-catalog data-pagefind-body>
    <SectionHeading
      eyebrow="PROJECT INDEX"
      title="公开项目目录"
      description="不是概念稿，而是经过源码整理和安全检查、可以继续查看实现过程的产品与工具。"
      level="h1"
    />

    <section class="project-catalog__overview" aria-label="项目目录概览">
      <div class="project-catalog__count">
        <strong data-project-count={projects.length}>{projects.length}</strong>
        <span>公开项目</span>
      </div>
      <div class="project-catalog__categories" aria-label="五类项目说明">
        {projectCategories.map((category, index) => (
          <article>
            <span aria-hidden="true">{String(index + 1).padStart(2, '0')}</span>
            <h2>{category}</h2>
            <p>{categoryDescriptions[category]}</p>
          </article>
        ))}
      </div>
    </section>

    <div class="project-catalog__gallery">
      <ProjectGallery projects={projects} />
    </div>
  </div>
</BaseLayout>

<style>
  .page-shell {
    padding-block: clamp(62px, 8vw, 100px) 110px;
  }

  .project-catalog__overview {
    display: grid;
    grid-template-columns: minmax(170px, 0.22fr) minmax(0, 1fr);
    gap: 14px;
    margin-bottom: 56px;
  }

  .project-catalog__count,
  .project-catalog__categories article {
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    background: var(--surface);
  }

  .project-catalog__count {
    display: flex;
    min-height: 196px;
    flex-direction: column;
    justify-content: flex-end;
    padding: 22px;
    color: var(--accent-ink);
    border-color: var(--accent);
    background: var(--accent);
  }

  .project-catalog__count strong {
    font-family: 'Geist Mono', ui-monospace, monospace;
    font-size: clamp(3.2rem, 7vw, 5.4rem);
    letter-spacing: -0.08em;
    line-height: 0.9;
  }

  .project-catalog__count span {
    margin-top: 16px;
    font-size: 0.88rem;
    font-weight: 720;
  }

  .project-catalog__categories {
    display: grid;
    grid-template-columns: repeat(5, minmax(0, 1fr));
    gap: 10px;
  }

  .project-catalog__categories article {
    min-width: 0;
    padding: 18px;
  }

  .project-catalog__categories article > span {
    color: var(--secondary-strong);
    font-family: 'Geist Mono', ui-monospace, monospace;
    font-size: 0.7rem;
    font-weight: 700;
  }

  .project-catalog__categories h2 {
    margin: 28px 0 8px;
    font-size: 1rem;
    letter-spacing: -0.02em;
    line-height: 1.2;
  }

  .project-catalog__categories p {
    margin: 0;
    color: var(--muted);
    font-size: 0.78rem;
    line-height: 1.55;
  }

  .project-catalog__gallery {
    padding-top: 34px;
    border-top: 1px solid var(--border);
  }

  @media (max-width: 980px) {
    .project-catalog__overview {
      grid-template-columns: 1fr;
    }

    .project-catalog__count {
      min-height: 150px;
    }

    .project-catalog__categories {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }

  @media (max-width: 640px) {
    .page-shell {
      padding-block: 52px 88px;
    }

    .project-catalog__overview {
      margin-bottom: 44px;
    }

    .project-catalog__categories {
      grid-template-columns: 1fr;
    }

    .project-catalog__categories article {
      padding: 16px 18px;
    }

    .project-catalog__categories h2 {
      margin-top: 14px;
    }
  }
</style>

