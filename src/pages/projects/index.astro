---
import { getCollection } from 'astro:content';

import ProjectGallery from '../../components/ProjectGallery.astro';
import SectionHeading from '../../components/SectionHeading.astro';
import { isVisibleEntry, sortByPublishedAt } from '../../lib/content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const projects = sortByPublishedAt(
  (await getCollection('projects')).filter((entry) => isVisibleEntry(entry, import.meta.env.PROD)),
);
---

<BaseLayout title="项目作品" description="已经完成源码整理和安全检查的产品与工具，每个项目都可以查看实现过程和 GitHub 源码。">
  <div class="container page-shell" data-pagefind-body>
    <SectionHeading
      eyebrow="PROJECT INDEX"
      title="项目作品"
      description="这里展示已经完成源码整理和安全检查的产品与工具。每个项目都可以查看实现过程和 GitHub 源码。"
    />

    <ProjectGallery projects={projects} />
  </div>
</BaseLayout>

<style>
  .page-shell {
    padding-block: clamp(72px, 10vw, 124px) 110px;
  }

</style>

