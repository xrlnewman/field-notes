---
import { getCollection } from 'astro:content';

import ProjectGallery from '../../components/ProjectGallery.astro';
import SectionHeading from '../../components/SectionHeading.astro';
import { isVisibleEntry, sortByPublishedAt } from '../../lib/content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const projects = sortByPublishedAt(
  (await getCollection('projects')).filter((entry) => isVisibleEntry(entry, import.meta.env.PROD)),
);
---

<BaseLayout title="项目作品" description="三十个网站产品及其关联仓库，每个项目都可以查看产品组成和 GitHub 源码。">
  <div class="container page-shell" data-project-catalog data-pagefind-body>
    <header class="project-catalog__hero" data-reveal>
      <SectionHeading
        eyebrow="PRODUCT CONSTELLATION"
        title="三十个可运行的网站产品"
        description="每张卡片代表一个完整产品；进入详情即可查看前台、运营后台与服务端之间的关联。"
        level="h1"
      />
      <p class="project-catalog__count">
        <strong data-project-count={projects.length}>{projects.length}</strong>
        <span>个公开网站产品</span>
      </p>
    </header>

    <div class="project-catalog__gallery" data-reveal>
      <ProjectGallery projects={projects} />
    </div>
  </div>
</BaseLayout>

<style>
  .page-shell {
    padding-block: clamp(64px, 8vw, 96px) 96px;
  }

  .project-catalog__hero {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: clamp(36px, 7vw, 100px);
    align-items: end;
    margin-bottom: 40px;
    padding-bottom: 36px;
    border-bottom: 1px solid var(--border);
  }

  .project-catalog__count {
    display: flex;
    min-width: 160px;
    min-height: 0;
    flex-direction: column;
    justify-content: flex-end;
    margin: 0;
    padding: 24px 0 0;
    border-top: 1px solid var(--accent);
  }

  .project-catalog__count strong {
    color: var(--accent-strong);
    font-size: clamp(3rem, 6vw, 4.5rem);
    line-height: 0.9;
  }

  .project-catalog__count span {
    margin-top: 18px;
    color: var(--muted);
    font-size: 0.94rem;
  }

  .project-catalog__gallery {
    min-width: 0;
  }

  @media (max-width: 980px) {
    .project-catalog__hero {
      grid-template-columns: 1fr;
    }

    .project-catalog__count {
      min-height: 0;
    }
  }

  @media (max-width: 640px) {
    .page-shell {
      padding-block: 72px 92px;
    }
  }
</style>

