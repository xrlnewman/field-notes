---
import { getCollection } from 'astro:content';

import ContentCard from '../../components/ContentCard.astro';
import SectionHeading from '../../components/SectionHeading.astro';
import { isVisibleEntry, sortByPublishedAt } from '../../lib/content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const projects = sortByPublishedAt(
  (await getCollection('projects')).filter((entry) => isVisibleEntry(entry, import.meta.env.PROD)),
);
---

<BaseLayout title="项目" description="正在构建和已经完成的产品、工具与公开实验。">
  <div class="container page-shell" data-pagefind-body>
    <SectionHeading
      eyebrow="PROJECT INDEX"
      title="项目与产品实验"
      description="不只展示结果，也记录问题、实现路径和最后的取舍。"
    />

    <div class="content-grid">
      {projects.map((project, index) => (
        <ContentCard
          type="project"
          href={`/projects/${project.id}/`}
          title={project.data.title}
          description={project.data.description}
          publishedAt={project.data.publishedAt}
          meta={project.data.status === 'active' ? '持续迭代' : project.data.status === 'completed' ? '已经完成' : '已归档'}
          tags={project.data.tech}
          featured={index === 0}
        />
      ))}
    </div>
  </div>
</BaseLayout>

<style>
  .page-shell {
    padding-block: clamp(72px, 10vw, 124px) 110px;
  }

  .content-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 18px;
  }

  @media (max-width: 760px) {
    .content-grid { grid-template-columns: 1fr; }
  }
</style>

