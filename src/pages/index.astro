---
import { getCollection } from 'astro:content';

import ContentCard from '../components/ContentCard.astro';
import ProjectCard from '../components/ProjectCard.astro';
import SectionHeading from '../components/SectionHeading.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import { siteConfig } from '../config/site';
import { isVisibleEntry, sortByPublishedAt } from '../lib/content';

const projects = sortByPublishedAt(
  (await getCollection('projects')).filter((entry) => isVisibleEntry(entry, import.meta.env.PROD)),
);
const articles = sortByPublishedAt(
  (await getCollection('articles')).filter((entry) => isVisibleEntry(entry, import.meta.env.PROD)),
);
---

<BaseLayout title={siteConfig.title}>
  <div class="container">
    <section class="hero">
      <div>
        <p class="eyebrow">PRODUCT ENGINEER · BUILDER · WRITER</p>
        <h1>把复杂业务，做成真正可用的产品。</h1>
        <p class="hero__intro">{siteConfig.description}</p>
        <div class="button-row">
          <a class="button button--primary" href="/projects/">查看项目 <span aria-hidden="true">→</span></a>
          <a class="button" href="/articles/">阅读文章</a>
        </div>
      </div>
      <aside class="hero__panel" aria-label="当前状态">
        <span class="status">7 年持续交付</span>
        <h2>当前关注</h2>
        <p>把工程经验转化为可复用的产品、工具和文章，持续记录从需求判断到上线交付的完整过程。</p>
      </aside>
    </section>

    <section class="home-section" data-pagefind-ignore>
      <SectionHeading
        eyebrow="SELECTED PROJECTS"
        title="项目作品"
        description="每个公开项目都经过源码整理和安全检查，可以查看实现过程与 GitHub 仓库。"
        href="/projects/"
      />
      <div class="home-grid home-grid--projects">
        {projects.slice(0, 6).map((project) => (
          <ProjectCard
            href={`/projects/${project.id}/`}
            title={project.data.title}
            description={project.data.description}
            cover={project.data.cover!}
            category={project.data.category}
            status={project.data.status}
            tech={project.data.tech}
            repoUrl={project.data.repoUrl!}
          />
        ))}
      </div>
    </section>

    <section class="home-section home-section--last" data-pagefind-ignore>
      <SectionHeading eyebrow="LATEST WRITING" title="最近写下的内容" href="/articles/" />
      <div class="home-grid">
        {articles.slice(0, 4).map((article) => (
          <ContentCard
            type="article"
            href={`/articles/${article.id}/`}
            title={article.data.title}
            description={article.data.description}
            publishedAt={article.data.publishedAt}
            tags={article.data.tags}
          />
        ))}
      </div>
    </section>
  </div>
</BaseLayout>

<style>
  .home-section {
    padding-block: 88px;
    border-top: 1px solid var(--border);
  }

  .home-section--last {
    padding-bottom: 120px;
  }

  .hero {
    padding-block: clamp(64px, 8vw, 104px) clamp(52px, 7vw, 78px);
  }

  .home-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 18px;
  }

  .home-grid--projects {
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  @media (max-width: 960px) {
    .home-grid--projects { grid-template-columns: repeat(2, minmax(0, 1fr)); }
  }

  @media (max-width: 760px) {
    .home-grid { grid-template-columns: 1fr; }
  }
</style>
