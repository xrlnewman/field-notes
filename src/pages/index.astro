---
import { getCollection } from 'astro:content';

import ContentCard from '../components/ContentCard.astro';
import SectionHeading from '../components/SectionHeading.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import { siteConfig } from '../config/site';
import { isVisibleEntry, sortByPublishedAt } from '../lib/content';

const projects = sortByPublishedAt(
  (await getCollection('projects')).filter((entry) => isVisibleEntry(entry, import.meta.env.PROD)),
);
const articles = sortByPublishedAt(
  (await getCollection('articles')).filter((entry) => isVisibleEntry(entry, import.meta.env.PROD)),
);
---

<BaseLayout title={siteConfig.title}>
  <div class="container">
    <section class="hero">
      <div>
        <p class="eyebrow">BUILD · LEARN · SHARE</p>
        <h1>做有用的东西，写真实的过程。</h1>
        <p class="hero__intro">{siteConfig.description}</p>
        <div class="button-row">
          <a class="button button--primary" href="/projects/">查看项目 <span aria-hidden="true">→</span></a>
          <a class="button" href="/articles/">阅读文章</a>
        </div>
      </div>
      <aside class="hero__panel" aria-label="当前状态">
        <span class="status">持续构建中</span>
        <h2>当前关注</h2>
        <p>把互联网趋势转化为能真正使用的产品，并记录从判断、开发到发布的完整过程。</p>
      </aside>
    </section>

    <section class="home-section" data-pagefind-ignore>
      <SectionHeading eyebrow="FEATURED PROJECTS" title="正在做的项目" href="/projects/" />
      <div class="home-grid home-grid--projects">
        {projects.slice(0, 3).map((project, index) => (
          <ContentCard
            type="project"
            href={`/projects/${project.id}/`}
            title={project.data.title}
            description={project.data.description}
            publishedAt={project.data.publishedAt}
            meta={project.data.status === 'active' ? '持续迭代' : '查看复盘'}
            tags={project.data.tech}
            featured={index === 0}
          />
        ))}
      </div>
    </section>

    <section class="home-section home-section--last" data-pagefind-ignore>
      <SectionHeading eyebrow="LATEST WRITING" title="最近写下的内容" href="/articles/" />
      <div class="home-grid">
        {articles.slice(0, 4).map((article) => (
          <ContentCard
            type="article"
            href={`/articles/${article.id}/`}
            title={article.data.title}
            description={article.data.description}
            publishedAt={article.data.publishedAt}
            tags={article.data.tags}
          />
        ))}
      </div>
    </section>
  </div>
</BaseLayout>

<style>
  .home-section {
    padding-block: 88px;
    border-top: 1px solid var(--border);
  }

  .home-section--last {
    padding-bottom: 120px;
  }

  .home-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 18px;
  }

  .home-grid--projects :global(.content-card:first-child) {
    grid-column: span 2;
  }

  @media (max-width: 760px) {
    .home-grid { grid-template-columns: 1fr; }
    .home-grid--projects :global(.content-card:first-child) { grid-column: auto; }
  }
</style>
