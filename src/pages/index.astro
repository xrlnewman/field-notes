---
import { getCollection } from 'astro:content';

import ContentCard from '../components/ContentCard.astro';
import ProjectCard from '../components/ProjectCard.astro';
import ProjectCategoryGrid from '../components/ProjectCategoryGrid.astro';
import SectionHeading from '../components/SectionHeading.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import { siteConfig } from '../config/site';
import { isVisibleEntry, sortByPublishedAt } from '../lib/content';
import { projectCategories } from '../lib/projects';

const projects = sortByPublishedAt(
  (await getCollection('projects')).filter((entry) => isVisibleEntry(entry, import.meta.env.PROD)),
);
const articles = sortByPublishedAt(
  (await getCollection('articles')).filter((entry) => isVisibleEntry(entry, import.meta.env.PROD)),
);
---

<BaseLayout title={siteConfig.title}>
  <div class="container">
    <section class="hero-studio">
      <div class="hero-studio__copy">
        <p class="eyebrow">PRODUCT ENGINEER · BUILDER · WRITER</p>
        <h1>把复杂业务，做成真正可用的产品。</h1>
        <p class="hero-studio__intro">{siteConfig.description}</p>
        <div class="button-row">
          <a class="button button--primary" href="/projects/">查看项目 <span aria-hidden="true">→</span></a>
          <a class="button" href="/articles/">阅读文章</a>
        </div>
      </div>
      <aside class="hero-studio__stats" aria-label="工作室数据">
        <div class="hero-studio__stat hero-studio__stat--primary">
          <strong data-project-count={projects.length}>{projects.length}</strong>
          <span>公开项目</span>
          <small>均可查看详情与源码</small>
        </div>
        <div class="hero-studio__stat">
          <strong>{projectCategories.length}</strong>
          <span>项目分类</span>
        </div>
        <div class="hero-studio__stat">
          <strong>{siteConfig.author.experienceYears} 年</strong>
          <span>开发经验</span>
        </div>
      </aside>
    </section>

    <section class="home-section home-section--projects" data-home-project-catalog data-pagefind-ignore>
      <SectionHeading
        eyebrow="SELECTED PROJECTS"
        title="项目作品"
        description="每个公开项目都经过源码整理和安全检查，可以查看实现过程与 GitHub 仓库。"
        href="/projects/"
      />
      <ProjectCategoryGrid projects={projects} />
      <div class="home-grid home-grid--projects">
        {projects.slice(0, 6).map((project) => (
          <ProjectCard
            href={`/projects/${project.id}/`}
            title={project.data.title}
            description={project.data.description}
            cover={project.data.cover!}
            category={project.data.category}
            status={project.data.status}
            tech={project.data.tech}
            repoUrl={project.data.repoUrl!}
          />
        ))}
      </div>
    </section>

    <section class="home-section home-section--last" data-pagefind-ignore>
      <SectionHeading eyebrow="LATEST WRITING" title="最近写下的内容" href="/articles/" />
      <div class="home-grid">
        {articles.slice(0, 4).map((article) => (
          <ContentCard
            type="article"
            href={`/articles/${article.id}/`}
            title={article.data.title}
            description={article.data.description}
            publishedAt={article.data.publishedAt}
            tags={article.data.tags}
          />
        ))}
      </div>
    </section>
  </div>
</BaseLayout>

<style>
  .hero-studio {
    display: grid;
    grid-template-columns: minmax(0, 1.35fr) minmax(360px, 0.65fr);
    gap: clamp(30px, 5vw, 72px);
    align-items: center;
    padding-block: clamp(44px, 5vw, 68px) clamp(38px, 4vw, 52px);
  }

  .hero-studio__copy,
  .hero-studio__stats {
    min-width: 0;
  }

  .hero-studio h1 {
    max-width: 760px;
    margin: 0;
    font-size: clamp(3rem, 6vw, 5.4rem);
    font-weight: 680;
    letter-spacing: -0.068em;
    line-height: 0.98;
  }

  .hero-studio__intro {
    max-width: 620px;
    margin: 22px 0 0;
    color: var(--muted);
    font-size: clamp(1.02rem, 1.7vw, 1.2rem);
  }

  .hero-studio__stats {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 12px;
  }

  .hero-studio__stat {
    display: flex;
    min-height: 112px;
    flex-direction: column;
    justify-content: flex-end;
    padding: 20px;
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    background: color-mix(in srgb, var(--surface) 92%, transparent);
    box-shadow: 0 12px 32px color-mix(in srgb, var(--ink) 7%, transparent);
  }

  .hero-studio__stat--primary {
    min-height: 136px;
    grid-column: 1 / -1;
    color: var(--accent-ink);
    border-color: var(--accent);
    background: var(--accent);
  }

  .hero-studio__stat strong {
    font-family: 'Geist Mono', ui-monospace, monospace;
    font-size: clamp(2rem, 4vw, 3.4rem);
    letter-spacing: -0.07em;
    line-height: 1;
  }

  .hero-studio__stat span {
    margin-top: 10px;
    font-size: 0.9rem;
    font-weight: 720;
  }

  .hero-studio__stat small {
    margin-top: 4px;
    color: color-mix(in srgb, var(--accent-ink) 74%, transparent);
    font-size: 0.74rem;
  }

  .home-section {
    padding-block: 64px;
    border-top: 1px solid var(--border);
  }

  .home-section--projects {
    padding-top: 44px;
  }

  .home-section--last {
    padding-bottom: 120px;
  }

  .home-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 18px;
  }

  .home-grid--projects {
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  @media (max-width: 960px) {
    .hero-studio {
      grid-template-columns: 1fr;
    }

    .hero-studio__stats {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }

    .hero-studio__stat--primary {
      min-height: 132px;
      grid-column: auto;
    }

    .home-grid--projects { grid-template-columns: repeat(2, minmax(0, 1fr)); }
  }

  @media (max-width: 760px) {
    .hero-studio {
      gap: 32px;
      padding-block: 48px 44px;
    }

    .hero-studio h1 {
      font-size: clamp(2.75rem, 14vw, 4.2rem);
    }

    .hero-studio__stats {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .hero-studio__stat--primary {
      grid-column: 1 / -1;
    }

    .home-section {
      padding-block: 56px;
    }

    .home-grid { grid-template-columns: 1fr; }
  }

  @media (max-width: 380px) {
    .hero-studio__stats {
      grid-template-columns: 1fr;
    }

    .hero-studio__stat--primary {
      grid-column: auto;
    }
  }
</style>
