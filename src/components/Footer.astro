---
import { siteConfig } from '../config/site';

const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="container footer-grid">
    <div>
      <a class="footer-brand" href="/">{siteConfig.brand}</a>
      <p>{siteConfig.description}</p>
    </div>
    <div class="footer-links" aria-label="页脚链接">
      <a href="/rss.xml">RSS</a>
      <a href="/guestbook/">留言板</a>
      {siteConfig.social.github && (
        <a href={siteConfig.social.github} target="_blank" rel="noopener noreferrer">GitHub</a>
      )}
    </div>
  </div>
  <div class="container footer-bottom">
    <span>© {year} {siteConfig.author.name}</span>
    <span>Astro · Cloudflare Pages · Cloudflare D1</span>
  </div>
</footer>

<style>
  .site-footer {
    padding-block: 56px 28px;
    border-top: 1px solid var(--border);
    background: color-mix(in srgb, var(--space-0) 74%, transparent);
    box-shadow: 0 -18px 54px color-mix(in srgb, var(--space-0) 42%, transparent);
    backdrop-filter: blur(20px) saturate(125%);
    -webkit-backdrop-filter: blur(20px) saturate(125%);
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 48px;
  }

  .footer-brand {
    font-weight: 700;
    text-decoration: none;
  }

  .footer-grid p {
    max-width: 520px;
    margin: 10px 0 0;
    color: var(--muted);
  }

  .footer-links {
    display: flex;
    gap: 20px;
  }

  .footer-bottom {
    display: flex;
    justify-content: space-between;
    gap: 24px;
    margin-top: 46px;
    padding-top: 18px;
    border-top: 1px solid var(--border);
    color: var(--muted);
    font-family: var(--font-sans);
    font-size: 0.73rem;
  }

  @media (max-width: 640px) {
    .footer-grid {
      grid-template-columns: 1fr;
      gap: 28px;
    }

    .footer-bottom {
      align-items: flex-start;
      flex-direction: column;
      gap: 6px;
    }
  }
</style>

