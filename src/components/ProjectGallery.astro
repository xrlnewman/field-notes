---
import type { CollectionEntry } from 'astro:content';

import { getProjectCategoryStats } from '../lib/projects';
import Pagination from './Pagination.astro';
import ProjectCard from './ProjectCard.astro';

interface Props {
  projects: CollectionEntry<'projects'>[];
}

const { projects } = Astro.props;
const pageSize = 6;
const totalPages = Math.max(1, Math.ceil(projects.length / pageSize));
const requestedPage = Number(Astro.url.searchParams.get('page') ?? '1');
const currentPage = Number.isInteger(requestedPage)
  ? Math.min(Math.max(requestedPage, 1), totalPages)
  : 1;
const requestedCategory = Astro.url.searchParams.get('category');
const filters = [
  { category: '全部' as const, count: projects.length },
  ...getProjectCategoryStats(projects),
];
const orderedProjects = [...projects].sort((left, right) =>
  Number(right.id === 'field-notes') - Number(left.id === 'field-notes'),
);
---

<section class="project-gallery-shell" aria-label="项目作品筛选">
  <div class="project-filters" role="group" aria-label="按项目类型筛选">
    {filters.map(({ category, count }) => (
      <button
        type="button"
        data-project-filter={category}
        data-project-filter-count={count}
        aria-pressed={category === '全部' ? 'true' : 'false'}
        aria-controls="project-gallery"
      >
        <span>{category}</span>
        <span class="project-filter__count" aria-label={`${count} 个项目`}>{count}</span>
      </button>
    ))}
  </div>

  <div id="project-gallery" class="project-gallery" data-project-gallery>
    {orderedProjects.map((project, index) => (
      <ProjectCard
        href={`/projects/${project.id}/`}
        title={project.data.title}
        description={project.data.description}
        cover={project.data.cover!}
        category={project.data.category}
        status={project.data.status}
        tech={project.data.tech}
        repoUrl={project.data.repoUrl!}
        repositories={project.data.repositories}
        coverViewport={project.data.screenshots?.[0]?.viewport ?? 'desktop'}
        page={Math.floor(index / pageSize) + 1}
        featured={project.id === 'field-notes'}
      />
    ))}
  </div>

  <p class="project-empty" data-project-empty hidden>这个分类还没有公开项目。</p>
  <Pagination
    currentPage={currentPage}
    totalPages={totalPages}
    basePath="/projects/"
    query={requestedCategory ? { category: requestedCategory } : {}}
    ariaLabel="项目分页"
    dataAttribute="project-pagination"
  />
</section>

<script>
  import { getProjectCategoryUrl, parseProjectCategory } from '../lib/projects';

  const gallery = document.querySelector<HTMLElement>('[data-project-gallery]');
  const buttons = document.querySelectorAll<HTMLButtonElement>('[data-project-filter]');
  const empty = document.querySelector<HTMLElement>('[data-project-empty]');
  const pagination = document.querySelector<HTMLElement>('[data-pagination="project-pagination"]');
  const pageLinks = pagination?.querySelectorAll<HTMLAnchorElement>('[data-pagination-page]') ?? [];
  const previous = pagination?.querySelector<HTMLAnchorElement>('[data-pagination-prev]');
  const next = pagination?.querySelector<HTMLAnchorElement>('[data-pagination-next]');
  const pageSize = 6;
  let activeFilter = '全部';
  let activePage = Number(new URLSearchParams(window.location.search).get('page') ?? '1');
  if (!Number.isInteger(activePage) || activePage < 1) activePage = 1;

  const updateLink = (link: HTMLAnchorElement | null, page: number, filter: string) => {
    if (!link) return;
    const url = new URL(window.location.href);
    if (filter === '全部') url.searchParams.delete('category');
    else url.searchParams.set('category', filter);
    if (page <= 1) url.searchParams.delete('page');
    else url.searchParams.set('page', String(page));
    link.href = url.toString();
  };

  const setDisabled = (link: HTMLAnchorElement | null, disabled: boolean) => {
    if (!link) return;
    link.classList.toggle('pagination__arrow--disabled', disabled);
    link.setAttribute('aria-disabled', String(disabled));
  };

  const applyFilter = (filter: string, requestedPage = activePage) => {
    let visible = 0;
    const cards = Array.from(gallery?.querySelectorAll<HTMLElement>('[data-project-category]') ?? []);
    const matches = cards.filter((card) => filter === '全部' || card.dataset.projectCategory === filter);
    const totalPages = Math.max(1, Math.ceil(matches.length / pageSize));
    activeFilter = filter;
    activePage = Math.min(Math.max(requestedPage, 1), totalPages);
    if (pagination) pagination.hidden = totalPages <= 1;

    buttons.forEach((button) => {
      button.setAttribute('aria-pressed', String(button.dataset.projectFilter === filter));
    });
    cards.forEach((card) => {
      const categoryMatch = filter === '全部' || card.dataset.projectCategory === filter;
      const index = matches.indexOf(card);
      const pageMatch = index >= 0 && Math.floor(index / pageSize) + 1 === activePage;
      card.hidden = !categoryMatch || !pageMatch;
      if (!card.hidden) visible += 1;
    });

    if (empty) empty.hidden = visible > 0;
    pageLinks.forEach((link) => {
      const page = Number(link.dataset.paginationPage);
      const isCurrent = page === activePage;
      link.hidden = page > totalPages;
      link.classList.toggle('pagination__page--current', isCurrent);
      if (isCurrent) link.setAttribute('aria-current', 'page');
      else link.removeAttribute('aria-current');
      updateLink(link, page, activeFilter);
    });
    updateLink(previous ?? null, Math.max(1, activePage - 1), activeFilter);
    updateLink(next ?? null, Math.min(totalPages, activePage + 1), activeFilter);
    setDisabled(previous ?? null, activePage <= 1);
    setDisabled(next ?? null, activePage >= totalPages);
  };

  const initialFilter = parseProjectCategory(new URLSearchParams(window.location.search).get('category'));
  applyFilter(initialFilter, activePage);

  buttons.forEach((button) => {
    button.addEventListener('click', () => {
      const filter = parseProjectCategory(button.dataset.projectFilter ?? null);

      applyFilter(filter, 1);
      const url = new URL(getProjectCategoryUrl(window.location.href, filter));
      url.searchParams.delete('page');
      window.history.replaceState({}, '', url);
    });
  });

  pageLinks.forEach((link) => {
    link.addEventListener('click', (event) => {
      event.preventDefault();
      applyFilter(activeFilter, Number(link.dataset.paginationPage));
      const url = new URL(link.href);
      window.history.replaceState({}, '', url);
    });
  });

  [previous, next].forEach((link) => {
    link?.addEventListener('click', (event) => {
      if (link.getAttribute('aria-disabled') === 'true') {
        event.preventDefault();
        return;
      }
      event.preventDefault();
      const target = new URL(link.href);
      applyFilter(activeFilter, Number(target.searchParams.get('page') ?? '1'));
      window.history.replaceState({}, '', target);
    });
  });
</script>

<style>
  .project-filters {
    display: flex;
    overflow-x: auto;
    gap: 4px;
    margin-bottom: 24px;
    padding: 0 0 8px;
    border-bottom: 1px solid var(--border);
    scrollbar-width: thin;
  }

  .project-filters button {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    min-height: 44px;
    flex: none;
    padding: 9px 14px;
    border: 0;
    border-bottom: 2px solid transparent;
    border-radius: 0;
    color: var(--muted);
    background: transparent;
    font: inherit;
    font-size: 0.86rem;
    font-weight: 600;
    cursor: pointer;
  }

  .project-filter__count {
    min-width: auto;
    padding: 0;
    color: var(--muted);
    background: transparent;
    font-family: var(--font-sans);
    font-size: 0.72rem;
    text-align: center;
  }

  .project-filters button:hover,
  .project-filters button[aria-pressed='true'] {
    color: var(--ink);
    border-bottom-color: var(--accent);
    background: color-mix(in srgb, var(--accent) 7%, transparent);
  }

  .project-filters button:hover .project-filter__count,
  .project-filters button[aria-pressed='true'] .project-filter__count {
    color: var(--accent-strong);
    background: transparent;
  }

  .project-filters button:focus-visible {
    outline: 3px solid color-mix(in srgb, var(--accent) 35%, transparent);
    outline-offset: 2px;
  }

  .project-gallery {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 24px;
  }

  .project-empty {
    margin: 28px 0 0;
    padding: 28px;
    border: 1px dashed var(--border);
    border-radius: var(--radius-md);
    color: var(--muted);
    text-align: center;
  }

  @media (max-width: 720px) {
    .project-gallery { grid-template-columns: 1fr; }
  }
</style>
