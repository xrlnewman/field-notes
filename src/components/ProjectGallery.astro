---
import type { CollectionEntry } from 'astro:content';

import { getProjectCategories } from '../lib/projects';
import ProjectCard from './ProjectCard.astro';

interface Props {
  projects: CollectionEntry<'projects'>[];
}

const { projects } = Astro.props;
const categories = getProjectCategories(projects);
---

<section class="project-gallery-shell" aria-label="项目作品筛选">
  <div class="project-filters" role="group" aria-label="按项目类型筛选">
    {categories.map((category) => (
      <button
        type="button"
        data-project-filter={category}
        aria-pressed={category === '全部' ? 'true' : 'false'}
        aria-controls="project-gallery"
      >
        {category}
      </button>
    ))}
  </div>

  <div id="project-gallery" class="project-gallery" data-project-gallery>
    {projects.map((project) => (
      <ProjectCard
        href={`/projects/${project.id}/`}
        title={project.data.title}
        description={project.data.description}
        cover={project.data.cover!}
        category={project.data.category}
        status={project.data.status}
        tech={project.data.tech}
        repoUrl={project.data.repoUrl!}
      />
    ))}
  </div>

  <p class="project-empty" data-project-empty hidden>这个分类还没有公开项目。</p>
</section>

<script>
  const gallery = document.querySelector<HTMLElement>('[data-project-gallery]');
  const buttons = document.querySelectorAll<HTMLButtonElement>('[data-project-filter]');
  const empty = document.querySelector<HTMLElement>('[data-project-empty]');

  buttons.forEach((button) => {
    button.addEventListener('click', () => {
      const filter = button.dataset.projectFilter ?? '全部';
      let visible = 0;

      buttons.forEach((item) => item.setAttribute('aria-pressed', String(item === button)));
      gallery?.querySelectorAll<HTMLElement>('[data-project-category]').forEach((card) => {
        const matches = filter === '全部' || card.dataset.projectCategory === filter;
        card.hidden = !matches;
        if (matches) visible += 1;
      });

      if (empty) empty.hidden = visible > 0;
    });
  });
</script>

<style>
  .project-filters {
    display: flex;
    overflow-x: auto;
    gap: 10px;
    margin-bottom: 28px;
    padding-bottom: 4px;
    scrollbar-width: thin;
  }

  .project-filters button {
    min-height: 42px;
    flex: none;
    padding: 9px 16px;
    border: 1px solid var(--border);
    border-radius: 999px;
    color: var(--muted);
    background: var(--surface);
    font: inherit;
    font-size: 0.86rem;
    font-weight: 650;
    cursor: pointer;
  }

  .project-filters button:hover,
  .project-filters button[aria-pressed='true'] {
    color: var(--canvas);
    border-color: var(--ink);
    background: var(--ink);
  }

  .project-filters button:focus-visible {
    outline: 3px solid color-mix(in srgb, var(--accent) 35%, transparent);
    outline-offset: 2px;
  }

  .project-gallery {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 20px;
  }

  .project-empty {
    margin: 28px 0 0;
    padding: 28px;
    border: 1px dashed var(--border);
    border-radius: var(--radius-md);
    color: var(--muted);
    text-align: center;
  }

  @media (max-width: 900px) {
    .project-gallery { grid-template-columns: repeat(2, minmax(0, 1fr)); }
  }

  @media (max-width: 640px) {
    .project-gallery { grid-template-columns: 1fr; }
  }
</style>
