---
import { cosmicThemes } from '../lib/cosmic-theme';
---

<div class="theme-toggle" role="group" aria-label="星空主题" data-theme-toggle>
  {
    cosmicThemes.map((theme) => (
      <button
        type="button"
        aria-label={theme.label}
        aria-pressed="false"
        data-theme={theme.id}
        title={theme.description}
      >
        <span class="theme-toggle__full-label">{theme.label}</span>
        <span class="theme-toggle__short-label" aria-hidden="true">{theme.shortLabel}</span>
      </button>
    ))
  }
</div>

<script is:inline>
  (() => {
    const toggle = document.currentScript?.previousElementSibling;
    const theme = document.documentElement.dataset.theme;
    toggle?.querySelectorAll('button[data-theme]').forEach((button) => {
      button.setAttribute('aria-pressed', String(button.getAttribute('data-theme') === theme));
    });
  })();
</script>

<script>
  import {
    COSMIC_THEME_STORAGE_KEY,
    resolveCosmicTheme,
    type CosmicTheme,
  } from '../lib/cosmic-theme';

  const buttons = document.querySelectorAll<HTMLButtonElement>('[data-theme-toggle] button[data-theme]');

  const updateButtons = (theme: CosmicTheme) => {
    buttons.forEach((button) => {
      button.setAttribute('aria-pressed', String(button.dataset.theme === theme));
    });
  };

  const currentTheme = resolveCosmicTheme(document.documentElement.dataset.theme);
  updateButtons(currentTheme);

  buttons.forEach((button) => {
    button.addEventListener('click', () => {
      const theme = resolveCosmicTheme(button.dataset.theme);
      document.documentElement.dataset.theme = theme;
      document.documentElement.style.colorScheme = 'dark';
      try {
        localStorage.setItem(COSMIC_THEME_STORAGE_KEY, theme);
      } catch {
        // 存储不可用时仍保留当前页面主题。
      }
      updateButtons(theme);
      document.dispatchEvent(new CustomEvent('cosmic-theme-change', { detail: { theme } }));
    });
  });
</script>

<style>
  .theme-toggle {
    display: inline-flex;
    gap: 2px;
    padding: 2px;
    border: 1px solid var(--border);
    border-radius: 999px;
    background: var(--surface);
  }

  .theme-toggle button {
    min-width: 44px;
    min-height: 44px;
    padding: 4px 8px;
    border: 0;
    border-radius: 999px;
    color: var(--ink);
    background-color: transparent;
    cursor: pointer;
    transition: color 280ms ease, background-color 280ms ease;
  }

  .theme-toggle__short-label {
    display: none;
  }

  :global(:root[data-theme='observatory']) .theme-toggle button[data-theme='observatory'],
  :global(:root[data-theme='nebula']) .theme-toggle button[data-theme='nebula'],
  :global(:root[data-theme='terminal']) .theme-toggle button[data-theme='terminal'] {
    color: var(--canvas);
    background-color: var(--accent);
  }

  @media (max-width: 520px) {
    .theme-toggle__full-label {
      display: none;
    }

    .theme-toggle__short-label {
      display: inline;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .theme-toggle button {
      transition: none;
    }
  }
</style>
