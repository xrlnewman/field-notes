---
interface Props {
  eyebrow: string;
  title: string;
  description?: string;
  href?: string;
  linkLabel?: string;
}

const { eyebrow, title, description, href, linkLabel = '查看全部' } = Astro.props;
---

<header class="section-heading">
  <div>
    <p class="eyebrow">{eyebrow}</p>
    <h2>{title}</h2>
    {description && <p class="section-description">{description}</p>}
  </div>
  {href && <a href={href}>{linkLabel} <span aria-hidden="true">→</span></a>}
</header>

<style>
  .section-heading {
    display: flex;
    align-items: end;
    justify-content: space-between;
    gap: 24px;
    margin-bottom: 30px;
  }

  h2 {
    margin: 0;
    font-size: clamp(2rem, 5vw, 3.6rem);
    letter-spacing: -0.055em;
    line-height: 1.06;
  }

  .section-description {
    max-width: 620px;
    margin: 14px 0 0;
    color: var(--muted);
  }

  a {
    flex: none;
    color: var(--accent-strong);
    font-weight: 650;
    text-decoration: none;
  }

  @media (max-width: 620px) {
    .section-heading {
      align-items: flex-start;
      flex-direction: column;
    }
  }
</style>

