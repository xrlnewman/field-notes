---
interface Props {
  eyebrow: string;
  title: string;
  description?: string;
  href?: string;
  linkLabel?: string;
  level?: 'h1' | 'h2';
}

const { eyebrow, title, description, href, linkLabel = '查看全部', level = 'h2' } = Astro.props;
---

<header class="section-heading">
  <div class="section-heading__copy">
    <p class="eyebrow">{eyebrow}</p>
    {level === 'h1' ? <h1>{title}</h1> : <h2>{title}</h2>}
    {description && <p class="section-description">{description}</p>}
  </div>
  {href && <a class="section-heading__link" href={href}>{linkLabel} <span aria-hidden="true">→</span></a>}
</header>

<style>
  .section-heading {
    display: flex;
    align-items: end;
    justify-content: space-between;
    gap: 24px;
    margin-bottom: 30px;
  }

  .section-heading__copy {
    min-width: 0;
  }

  h1,
  h2 {
    margin: 0;
    font-size: clamp(2rem, 4.8vw, 3.5rem);
    line-height: 1.06;
  }

  .section-description {
    max-width: 620px;
    margin: 14px 0 0;
    color: var(--muted);
  }

  .section-heading__link {
    display: inline-flex;
    min-height: 44px;
    align-items: center;
    gap: 8px;
    flex: none;
    padding: 8px 14px;
    border: 1px solid var(--border);
    border-radius: 999px;
    color: var(--ink);
    background: var(--surface);
    font-weight: 600;
    text-decoration: none;
  }

  .section-heading__link:hover {
    color: var(--accent-strong);
    border-color: var(--accent);
  }

  @media (max-width: 620px) {
    .section-heading {
      align-items: flex-start;
      flex-direction: column;
    }
  }
</style>

