---
import type { CollectionEntry } from 'astro:content';

interface Props {
  previous?: CollectionEntry<'articles'> | undefined;
  next?: CollectionEntry<'articles'> | undefined;
}

const { previous, next } = Astro.props;
---

{(previous || next) && (
  <nav class="article-nav" aria-label="文章翻页">
    {previous ? (
      <a href={`/articles/${previous.id}/`}>
        <span>← 较早文章</span>
        <strong>{previous.data.title}</strong>
      </a>
    ) : <span></span>}
    {next && (
      <a class="next" href={`/articles/${next.id}/`}>
        <span>较新文章 →</span>
        <strong>{next.data.title}</strong>
      </a>
    )}
  </nav>
)}

<style>
  .article-nav {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 12px;
    margin-top: 68px;
    padding-top: 24px;
    border-top: 1px solid var(--border);
  }

  a {
    display: flex;
    min-height: 110px;
    flex-direction: column;
    justify-content: space-between;
    padding: 18px;
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    background: var(--surface);
    text-decoration: none;
  }

  a:hover { border-color: var(--accent); color: var(--ink); }
  a.next { text-align: right; }

  span { color: var(--muted); font-size: 0.76rem; }
  strong { line-height: 1.35; }

  @media (max-width: 620px) {
    .article-nav { grid-template-columns: 1fr; }
  }
</style>
