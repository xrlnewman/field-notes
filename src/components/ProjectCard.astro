---
import type { ProjectCategory } from '../lib/projects';

import TagList from './TagList.astro';

interface Props {
  href: string;
  title: string;
  description: string;
  cover: string;
  category: ProjectCategory;
  status: 'active' | 'completed' | 'archived';
  tech: readonly string[];
  repoUrl: string;
}

const { href, title, description, cover, category, status, tech, repoUrl } = Astro.props;
const statusLabels = {
  active: '持续迭代',
  completed: '已经完成',
  archived: '已归档',
} as const;
---

<article class="project-card" data-project-category={category}>
  <a class="project-cover" href={href} aria-label={`查看项目：${title}`}>
    <img src={cover} alt={`${title} 界面截图`} width="960" height="600" loading="lazy" />
  </a>
  <div class="project-card__body">
    <div class="project-card__meta">
      <span>{category}</span>
      <span>{statusLabels[status]}</span>
    </div>
    <h3><a href={href}>{title}</a></h3>
    <p>{description}</p>
    <TagList tags={tech.slice(0, 3)} />
    <div class="project-card__actions">
      <a href={href}>查看项目 →</a>
      <a href={repoUrl} target="_blank" rel="noopener noreferrer">GitHub 源码 ↗</a>
    </div>
  </div>
</article>

<style>
  .project-card {
    height: 100%;
    overflow: hidden;
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    background: var(--surface);
    transition: transform 180ms ease, border-color 180ms ease, box-shadow 180ms ease;
  }

  .project-card:hover {
    border-color: color-mix(in srgb, var(--accent) 55%, var(--border));
    box-shadow: var(--shadow);
    transform: translateY(-4px);
  }

  .project-cover {
    display: block;
    overflow: hidden;
    aspect-ratio: 16 / 10;
    border-bottom: 1px solid var(--border);
    background: var(--surface-soft);
  }

  .project-cover img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 280ms ease;
  }

  .project-card:hover .project-cover img {
    transform: scale(1.025);
  }

  .project-card__body {
    display: flex;
    min-height: 310px;
    flex-direction: column;
    padding: 22px;
  }

  .project-card__meta {
    display: flex;
    justify-content: space-between;
    gap: 14px;
    color: var(--accent-strong);
    font-family: 'Geist Mono', ui-monospace, monospace;
    font-size: 0.7rem;
    font-weight: 650;
    letter-spacing: 0.04em;
  }

  h3 {
    margin: 28px 0 0;
    font-size: clamp(1.35rem, 2vw, 1.75rem);
    letter-spacing: -0.04em;
    line-height: 1.15;
  }

  h3 a {
    color: var(--ink);
    text-decoration: none;
  }

  p {
    margin: 12px 0 24px;
    color: var(--muted);
  }

  .project-card :global(.tag-list) {
    margin-top: auto;
  }

  .project-card__actions {
    display: flex;
    justify-content: space-between;
    gap: 18px;
    margin-top: 24px;
    padding-top: 16px;
    border-top: 1px solid var(--border);
  }

  .project-card__actions a {
    color: var(--muted);
    font-size: 0.8rem;
    font-weight: 650;
    text-decoration: none;
  }

  .project-card__actions a:hover {
    color: var(--accent-strong);
  }

  @media (max-width: 440px) {
    .project-card__body { min-height: 290px; padding: 19px; }
    .project-card__actions { align-items: flex-start; flex-direction: column; gap: 10px; }
  }
</style>
