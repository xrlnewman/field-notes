---
import type { ProjectCategory } from '../lib/projects';

import TagList from './TagList.astro';

interface Props {
  href: string;
  title: string;
  description: string;
  cover: string;
  category: ProjectCategory;
  status: 'active' | 'completed' | 'archived';
  tech: readonly string[];
  repoUrl: string;
}

const { href, title, description, cover, category, status, tech, repoUrl } = Astro.props;
const statusLabels = {
  active: '持续迭代',
  completed: '已经完成',
  archived: '已归档',
} as const;
---

<article class="project-card" data-project-category={category}>
  <a class="project-cover" href={href} aria-label={`查看项目：${title}`}>
    <img src={cover} alt={`${title} 界面截图`} width="960" height="600" loading="lazy" />
  </a>
  <div class="project-card__body">
    <div class="project-card__meta">
      <span class="project-card__category">{category}</span>
      <span class="project-card__status">{statusLabels[status]}</span>
    </div>
    <h3><a href={href}>{title}</a></h3>
    <p>{description}</p>
    <TagList tags={tech.slice(0, 2)} />
    <div class="project-card__actions">
      <a class="project-card__action project-card__action--primary" href={href}>查看详情 →</a>
      <a class="project-card__action" href={repoUrl} target="_blank" rel="noopener noreferrer">源码 ↗</a>
    </div>
  </div>
</article>

<style>
  .project-card {
    display: flex;
    height: 100%;
    min-width: 0;
    flex-direction: column;
    overflow: hidden;
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    background: var(--surface);
    transition: transform 180ms ease, border-color 180ms ease, box-shadow 180ms ease;
  }

  .project-card[hidden] {
    display: none;
  }

  .project-card:hover {
    border-color: color-mix(in srgb, var(--accent) 55%, var(--border));
    box-shadow: var(--shadow);
    transform: translateY(-4px);
  }

  .project-cover {
    display: block;
    overflow: hidden;
    aspect-ratio: 16 / 10;
    border-bottom: 1px solid var(--border);
    background: var(--surface-soft);
  }

  .project-cover:focus-visible {
    position: relative;
    z-index: 1;
  }

  .project-cover img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 280ms ease;
  }

  .project-card:hover .project-cover img {
    transform: scale(1.025);
  }

  .project-card__body {
    display: flex;
    min-height: 244px;
    flex: 1;
    flex-direction: column;
    padding: 18px;
  }

  .project-card__meta {
    display: flex;
    flex-wrap: wrap;
    gap: 7px;
  }

  .project-card__meta span {
    display: inline-flex;
    min-height: 26px;
    align-items: center;
    padding: 4px 9px;
    border-radius: 999px;
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.02em;
  }

  .project-card__category {
    color: var(--secondary-strong);
    background: var(--secondary-soft);
  }

  .project-card__status {
    color: var(--accent-strong);
    background: var(--accent-soft);
  }

  h3 {
    margin: 14px 0 0;
    overflow: hidden;
    font-size: clamp(1.18rem, 1.8vw, 1.48rem);
    line-height: 1.2;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  h3 a {
    color: var(--ink);
    text-decoration: none;
  }

  p {
    margin: 8px 0 16px;
    overflow: hidden;
    color: var(--muted);
    font-size: 0.88rem;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .project-card :global(.tag-list) {
    margin-top: 2px;
  }

  .project-card__actions {
    display: flex;
    gap: 8px;
    margin-top: auto;
    padding-top: 18px;
    border-top: 1px solid var(--border);
  }

  .project-card__action {
    display: inline-flex;
    min-height: 44px;
    align-items: center;
    justify-content: center;
    padding: 8px 12px;
    border: 1px solid var(--border);
    border-radius: 10px;
    color: var(--ink);
    background: var(--surface-soft);
    font-size: 0.8rem;
    font-weight: 700;
    text-decoration: none;
  }

  .project-card__action:hover {
    color: var(--ink);
    border-color: var(--secondary);
  }

  .project-card__action--primary {
    flex: 1;
    color: var(--accent-ink);
    border-color: var(--accent);
    background: var(--accent);
  }

  .project-card__action--primary:hover {
    color: var(--accent-ink);
    border-color: var(--accent-strong);
    background: var(--accent-strong);
  }

  @media (max-width: 440px) {
    .project-card__body { min-height: 238px; padding: 16px; }
    .project-card__action { padding-inline: 10px; }
  }
</style>
