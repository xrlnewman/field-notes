<div class="copy-announcer" aria-live="polite" aria-atomic="true" data-copy-announcer></div>

<script>
  const announcer = document.querySelector<HTMLElement>('[data-copy-announcer]');

  document.querySelectorAll<HTMLElement>('.prose pre').forEach((block) => {
    if (block.querySelector('[data-copy-code]')) return;
    const code = block.querySelector('code');
    if (!code) return;

    const button = document.createElement('button');
    button.type = 'button';
    button.className = 'copy-code';
    button.dataset.copyCode = '';
    button.textContent = '复制';
    button.setAttribute('aria-label', '复制代码');
    button.addEventListener('click', async () => {
      try {
        await navigator.clipboard.writeText(code.textContent ?? '');
        button.textContent = '已复制';
        if (announcer) announcer.textContent = '代码已复制到剪贴板';
        window.setTimeout(() => { button.textContent = '复制'; }, 1600);
      } catch {
        button.textContent = '复制失败';
        if (announcer) announcer.textContent = '复制失败，请手动选择代码';
      }
    });
    block.append(button);
  });
</script>

<style>
  .copy-announcer {
    position: absolute;
    width: 1px;
    height: 1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
  }

  :global(.prose pre) { position: relative; }

  :global(.copy-code) {
    position: absolute;
    top: 10px;
    right: 10px;
    padding: 5px 9px;
    border: 1px solid #33483f;
    border-radius: 7px;
    color: #b9cec5;
    background: #15221d;
    font-size: 0.72rem;
    cursor: pointer;
  }

  :global(.copy-code:hover) { color: #fff; border-color: #668378; }
</style>

