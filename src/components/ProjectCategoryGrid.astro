---
import type { CollectionEntry } from 'astro:content';

import { getProjectCategoryHref, getProjectCategoryStats } from '../lib/projects';

interface Props {
  projects: CollectionEntry<'projects'>[];
}

const { projects } = Astro.props;
const categoryStats = getProjectCategoryStats(projects);
---

<nav class="project-category-grid" aria-label="按分类浏览项目" data-project-category-grid>
  {categoryStats.map(({ category, count }) => (
    <a href={getProjectCategoryHref(category)}>
      <span class="project-category-grid__name">{category}</span>
      <span
        class="project-category-grid__count"
        data-project-category-count={count}
        aria-label={`${count} 个项目`}
      >{count}</span>
    </a>
  ))}
</nav>

<style>
  .project-category-grid {
    display: flex;
    overflow-x: auto;
    gap: 10px;
    margin: -2px 0 24px;
    padding: 2px 2px 6px;
    scrollbar-width: thin;
  }

  .project-category-grid a {
    display: inline-flex;
    min-height: 44px;
    flex: none;
    align-items: center;
    gap: 10px;
    padding: 8px 14px;
    border: 1px solid var(--border);
    border-radius: 999px;
    color: var(--ink);
    background: var(--surface);
    text-decoration: none;
    transition: color 180ms ease, border-color 180ms ease, background 180ms ease;
  }

  .project-category-grid a:hover {
    color: var(--canvas);
    border-color: var(--ink);
    background: var(--ink);
  }

  .project-category-grid a:focus-visible {
    outline: 3px solid color-mix(in srgb, var(--accent) 35%, transparent);
    outline-offset: 2px;
  }

  .project-category-grid__name {
    font-size: 0.86rem;
    font-weight: 700;
    white-space: nowrap;
  }

  .project-category-grid__count {
    min-width: 1.5rem;
    padding: 1px 6px;
    border-radius: 999px;
    color: var(--muted);
    background: var(--surface-soft);
    font-family: var(--font-sans);
    font-size: 0.72rem;
    text-align: center;
  }

  .project-category-grid a:hover .project-category-grid__count {
    color: var(--ink);
    background: var(--canvas);
  }
</style>
