---
import { readGiscusConfig } from '../lib/giscus';

interface Props {
  mapping: 'pathname' | 'specific';
  term?: string | undefined;
  title?: string;
}

const { mapping, term, title = '评论与回复' } = Astro.props;
const config = readGiscusConfig(import.meta.env);
const discussionsUrl = config ? `https://github.com/${config.repo}/discussions` : undefined;
---

<section
  class="comments"
  aria-labelledby="comments-title"
  data-giscus-host
  data-configured={Boolean(config)}
  data-mapping={mapping}
  data-term={term}
>
  <header>
    <p class="eyebrow">DISCUSSION</p>
    <h2 id="comments-title">{title}</h2>
    <p>评论由 GitHub Discussions 保存，登录 GitHub 后即可参与。</p>
  </header>

  {config ? (
    <div
      class="giscus-mount"
      data-giscus-mount
      data-repo={config.repo}
      data-repo-id={config.repoId}
      data-category={config.category}
      data-category-id={config.categoryId}
      data-mapping={mapping}
      data-term={term}
    >
      <p class="giscus-loading">评论区进入视口后自动加载。</p>
    </div>
  ) : (
    <div class="comments-fallback">
      <strong>评论区暂未启用</strong>
      <p>部署前请按照项目文档配置四个 Giscus 公开参数。正文和其他页面不受影响。</p>
    </div>
  )}

  {discussionsUrl && (
    <p class="discussion-link"><a href={discussionsUrl} target="_blank" rel="noopener noreferrer">直接前往 GitHub Discussions ↗</a></p>
  )}
</section>

<script>
  const hosts = document.querySelectorAll<HTMLElement>('[data-giscus-host][data-configured="true"]');

  const loadGiscus = (host: HTMLElement) => {
    const mount = host.querySelector<HTMLElement>('[data-giscus-mount]');
    if (!mount || mount.dataset.loaded === 'true') return;
    mount.dataset.loaded = 'true';
    mount.replaceChildren();

    const script = document.createElement('script');
    script.src = 'https://giscus.app/client.js';
    script.async = true;
    script.crossOrigin = 'anonymous';
    const attributes: Record<string, string> = {
      repo: mount.dataset.repo ?? '',
      'repo-id': mount.dataset.repoId ?? '',
      category: mount.dataset.category ?? '',
      'category-id': mount.dataset.categoryId ?? '',
      mapping: mount.dataset.mapping ?? 'pathname',
      strict: '0',
      'reactions-enabled': '1',
      'emit-metadata': '0',
      'input-position': 'top',
      theme: document.documentElement.dataset.theme === 'dark' ? 'dark' : 'light',
      lang: 'zh-CN',
      loading: 'lazy',
    };
    if (mount.dataset.term) attributes.term = mount.dataset.term;
    Object.entries(attributes).forEach(([name, value]) => script.setAttribute(`data-${name}`, value));
    mount.append(script);
  };

  if ('IntersectionObserver' in window) {
    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (!entry.isIntersecting) return;
        loadGiscus(entry.target as HTMLElement);
        observer.unobserve(entry.target);
      });
    }, { rootMargin: '420px 0px' });
    hosts.forEach((host) => observer.observe(host));
  } else {
    hosts.forEach(loadGiscus);
  }

  document.addEventListener('theme-change', (event) => {
    const theme = (event as CustomEvent<{ theme: 'light' | 'dark' }>).detail.theme;
    document.querySelectorAll<HTMLIFrameElement>('iframe.giscus-frame').forEach((frame) => {
      frame.contentWindow?.postMessage({ giscus: { setConfig: { theme } } }, 'https://giscus.app');
    });
  });
</script>

<style>
  .comments {
    padding-top: 48px;
    border-top: 1px solid var(--border);
  }

  .comments header h2 {
    margin: 0;
    font-size: clamp(2rem, 5vw, 3.2rem);
    letter-spacing: -0.055em;
  }

  .comments header > p:last-child { margin: 12px 0 0; color: var(--muted); }
  .giscus-mount { min-height: 180px; margin-top: 32px; }
  .giscus-loading { color: var(--muted); }

  .comments-fallback {
    margin-top: 28px;
    padding: 20px;
    border: 1px dashed var(--border);
    border-radius: var(--radius-md);
    background: var(--surface-soft);
  }

  .comments-fallback p { margin: 7px 0 0; color: var(--muted); }
  .discussion-link { margin: 18px 0 0; font-size: 0.86rem; }
  .discussion-link a { color: var(--accent-strong); font-weight: 650; }
</style>
