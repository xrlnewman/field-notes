---
import type { CollectionEntry } from 'astro:content';

import Comments from '../components/Comments.astro';
import RepositoryConstellation from '../components/RepositoryConstellation.astro';
import TagList from '../components/TagList.astro';
import BaseLayout from './BaseLayout.astro';

interface Props {
  project: CollectionEntry<'projects'>;
}

const { project } = Astro.props;
const { data } = project;
const hasMultipleRepositories = (data.repositories?.length ?? 0) > 1;
const date = new Intl.DateTimeFormat('zh-CN', { year: 'numeric', month: 'long', day: 'numeric' }).format(data.publishedAt);
const statusLabels = { active: '持续迭代', completed: '已经完成', archived: '已归档' } as const;
---

<BaseLayout title={data.title} description={data.description} type="article">
  <article class="project-detail">
    <header class="container project-hero" data-reveal>
      <div>
        <p class="eyebrow">PROJECT / {statusLabels[data.status]}</p>
        <h1>{data.title}</h1>
        <p class="project-description">{data.description}</p>
      </div>
      <dl class="project-meta">
        <div><dt>发布日期</dt><dd><time datetime={data.publishedAt.toISOString()}>{date}</time></dd></div>
        <div><dt>当前状态</dt><dd>{statusLabels[data.status]}</dd></div>
        <div><dt>技术与方向</dt><dd><TagList tags={data.tech} /></dd></div>
      </dl>
      {(data.demoUrl || data.repoUrl) && (
        <div class="button-row">
          {data.demoUrl && <a class="button button--primary" href={data.demoUrl} target="_blank" rel="noopener noreferrer">在线体验 ↗</a>}
          {data.repoUrl && <a class="button" href={data.repoUrl} target="_blank" rel="noopener noreferrer">GitHub 源码 ↗</a>}
        </div>
      )}
      {data.cover && (
        <figure class="project-showcase">
          <img src={data.cover} alt={`${data.title} 界面截图`} width="1440" height="900" loading="eager" />
        </figure>
      )}
    </header>

    <section class="container project-panorama" aria-labelledby="product-panorama-title" data-reveal>
      <div class="project-panorama__heading">
        <p class="eyebrow">ONE PRODUCT · CONNECTED CODEBASES</p>
        <h2 id="product-panorama-title">产品全景</h2>
        <p>
          {hasMultipleRepositories
            ? '一个产品，按用户前台、运营后台和服务端拆分职责，并通过清晰的源码节点保持关联。'
            : '一个产品，由一个仓库完整维护产品与源码，主仓库入口位于页面首屏。'}
        </p>
      </div>
      <RepositoryConstellation repositories={data.repositories ?? []} />
    </section>

    <div class="container project-body-grid" data-reveal>
      <div class="project-index" aria-hidden="true"><span>{project.id.slice(0, 2).toUpperCase()}</span></div>
      <div class="prose" data-pagefind-body>
        <slot />
      </div>
    </div>

    <div class="container comments-slot">
      <Comments resource={`project:${project.id}`} />
    </div>
  </article>
</BaseLayout>

<style>
  .project-hero {
    padding-block: clamp(84px, 11vw, 148px) clamp(64px, 8vw, 96px);
    border-bottom: 1px solid var(--border);
  }

  .project-hero h1 {
    max-width: 950px;
    margin: 0;
    font-size: clamp(3.25rem, 8vw, 6.4rem);
    line-height: 1.02;
  }

  .project-description {
    max-width: 720px;
    margin: 26px 0 0;
    color: var(--muted);
    font-size: clamp(1.1rem, 2vw, 1.35rem);
  }

  .project-meta {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 18px;
    margin: 72px 0 0;
  }

  .project-showcase {
    overflow: hidden;
    margin: 58px 0 0;
    aspect-ratio: 16 / 10;
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    background: var(--surface-soft);
    box-shadow: var(--shadow);
  }

  .project-showcase img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  .project-meta div {
    padding-top: 14px;
    border-top: 1px solid var(--border);
  }

  dt {
    color: var(--muted);
    font-family: var(--font-sans);
    font-size: 0.72rem;
    text-transform: uppercase;
  }

  dd {
    margin: 8px 0 0;
    font-weight: 600;
  }

  .project-panorama {
    display: grid;
    grid-template-columns: minmax(240px, 0.32fr) minmax(0, 0.68fr);
    gap: clamp(40px, 7vw, 96px);
    padding-block: clamp(80px, 10vw, 128px);
    border-bottom: 1px solid var(--border);
  }

  .project-panorama__heading h2 {
    margin: 0;
    font-size: clamp(2.2rem, 4.5vw, 3.6rem);
    line-height: 1.08;
  }

  .project-panorama__heading > p:last-child {
    margin: 22px 0 0;
    color: var(--muted);
    line-height: 1.75;
  }

  .project-body-grid {
    display: grid;
    grid-template-columns: 120px minmax(0, var(--prose));
    gap: 60px;
    justify-content: center;
    padding-block: 80px 110px;
  }

  .project-index span {
    position: sticky;
    top: 110px;
    display: grid;
    width: 64px;
    height: 64px;
    place-items: center;
    border-radius: 50%;
    color: var(--canvas);
    background: var(--ink);
    font-family: var(--font-sans);
    font-size: 0.76rem;
  }

  .prose {
    min-width: 0;
    font-size: 1.06rem;
    line-height: 1.8;
  }

  .prose :global(h2) {
    margin: 2.5em 0 0.7em;
    font-size: 1.8rem;
  }

  .prose :global(h2:first-child) {
    margin-top: 0;
  }

  .prose :global(p),
  .prose :global(li) {
    color: color-mix(in srgb, var(--ink) 86%, var(--muted));
  }

  .prose :global(pre) {
    overflow: auto;
    padding: 20px;
    border-radius: var(--radius-md);
    color: var(--code-ink);
    background: var(--code);
  }

  .comments-slot {
    max-width: var(--prose);
    padding-bottom: 100px;
  }

  @media (max-width: 760px) {
    .project-meta {
      grid-template-columns: 1fr;
    }

    .project-body-grid {
      grid-template-columns: 1fr;
      gap: 28px;
    }

    .project-panorama {
      grid-template-columns: 1fr;
      gap: 42px;
    }

    .project-index {
      display: none;
    }
  }
</style>

