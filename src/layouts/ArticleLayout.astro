---
import type { MarkdownHeading } from 'astro';
import type { CollectionEntry } from 'astro:content';

import ArticleNav from '../components/ArticleNav.astro';
import ContentCard from '../components/ContentCard.astro';
import GiscusComments from '../components/GiscusComments.astro';
import ProseEnhancements from '../components/ProseEnhancements.astro';
import TableOfContents from '../components/TableOfContents.astro';
import TagList from '../components/TagList.astro';
import { estimateReadingTime } from '../lib/content';
import BaseLayout from './BaseLayout.astro';

interface Props {
  article: CollectionEntry<'articles'>;
  headings: MarkdownHeading[];
  previous?: CollectionEntry<'articles'> | undefined;
  next?: CollectionEntry<'articles'> | undefined;
  related?: CollectionEntry<'articles'>[];
}

const { article, headings, previous, next, related = [] } = Astro.props;
const { data } = article;
const date = new Intl.DateTimeFormat('zh-CN', { year: 'numeric', month: 'long', day: 'numeric' }).format(data.publishedAt);
const readingTime = estimateReadingTime(article.body ?? '');
---

<BaseLayout title={data.title} description={data.description} image={data.cover} type="article">
  <article>
    <header class="container article-hero" data-pagefind-body>
      <p class="eyebrow">ARTICLE / {readingTime} MIN READ</p>
      <h1 data-pagefind-meta="title">{data.title}</h1>
      <p class="article-description">{data.description}</p>
      <div class="article-meta">
        <time datetime={data.publishedAt.toISOString()}>{date}</time>
        {data.updatedAt && <span>更新于 {new Intl.DateTimeFormat('zh-CN').format(data.updatedAt)}</span>}
        <span class="article-category">{data.category}</span>
        <TagList tags={data.tags} linked />
      </div>
    </header>

    <div class="container article-grid">
      <div class="prose" data-pagefind-body>
        <slot />
        <ArticleNav previous={previous} next={next} />
      </div>
      <TableOfContents headings={headings} />
    </div>

    {related.length > 0 && (
      <section class="container related" data-pagefind-ignore>
        <p class="eyebrow">RELATED WRITING</p>
        <h2>继续阅读</h2>
        <div class="related-grid">
          {related.map((entry) => (
            <ContentCard
              type="article"
              href={`/articles/${entry.id}/`}
              title={entry.data.title}
              description={entry.data.description}
              publishedAt={entry.data.publishedAt}
              category={entry.data.category}
              tags={entry.data.tags}
            />
          ))}
        </div>
      </section>
    )}

    <div class="container comments-slot"><GiscusComments mapping="pathname" /></div>
    <ProseEnhancements />
  </article>
</BaseLayout>

<style>
  .article-hero {
    max-width: 980px;
    padding-block: clamp(72px, 10vw, 128px) 66px;
    text-align: center;
  }

  .article-hero h1 {
    margin: 0;
    font-size: clamp(3rem, 8vw, 6.4rem);
    line-height: 1;
  }

  .article-description {
    max-width: 720px;
    margin: 24px auto 0;
    color: var(--muted);
    font-size: clamp(1.08rem, 2vw, 1.28rem);
  }

  .article-meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: center;
    gap: 12px 18px;
    margin-top: 30px;
    color: var(--muted);
    font-size: 0.82rem;
  }

  .article-grid {
    display: grid;
    grid-template-columns: minmax(0, var(--prose)) 220px;
    gap: 70px;
    justify-content: center;
    padding-block: 68px 110px;
    border-top: 1px solid var(--border);
  }

  .prose {
    min-width: 0;
    font-size: 1.0625rem;
    line-height: 1.82;
  }

  .prose :global(h2),
  .prose :global(h3) {
    scroll-margin-top: 100px;
    line-height: 1.25;
  }

  .prose :global(h2) { margin: 2.7em 0 0.75em; font-size: 1.85rem; }
  .prose :global(h3) { margin: 2.1em 0 0.65em; font-size: 1.35rem; }
  .prose :global(h2:first-child) { margin-top: 0; }

  .prose :global(p),
  .prose :global(li) {
    color: color-mix(in srgb, var(--ink) 87%, var(--muted));
  }

  .prose :global(a) { color: var(--accent-strong); }
  .prose :global(li + li) { margin-top: 0.45em; }

  .prose :global(blockquote) {
    margin: 2em 0;
    padding: 2px 0 2px 20px;
    border-left: 3px solid var(--accent);
    color: var(--muted);
  }

  .prose :global(code) {
    padding: 0.15em 0.35em;
    border: 1px solid var(--border);
    border-radius: 5px;
    background: var(--surface-soft);
    font-family: var(--font-sans);
    font-size: 0.86em;
  }

  .prose :global(pre) {
    overflow: auto;
    margin: 2em 0;
    padding: 22px;
    border: 1px solid #20332c;
    border-radius: var(--radius-md);
    color: var(--code-ink);
    background: var(--code) !important;
    line-height: 1.65;
  }

  .prose :global(pre code) {
    padding: 0;
    border: 0;
    color: inherit;
    background: transparent;
  }

  .prose :global(table) {
    width: 100%;
    overflow: hidden;
    border-collapse: collapse;
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
  }

  .prose :global(th),
  .prose :global(td) { padding: 10px 12px; border-bottom: 1px solid var(--border); text-align: left; }
  .prose :global(th) { background: var(--surface-soft); }

  .related {
    padding-block: 72px 100px;
    border-top: 1px solid var(--border);
  }

  .related h2 { margin: 0 0 28px; font-size: 2.3rem; }
  .related-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 18px; }
  .comments-slot { max-width: var(--prose); padding-bottom: 100px; }

  @media (max-width: 1000px) {
    .article-grid { grid-template-columns: minmax(0, var(--prose)); }
  }

  @media (max-width: 700px) {
    .article-hero { text-align: left; }
    .article-meta { justify-content: flex-start; }
    .related-grid { grid-template-columns: 1fr; }
  }
</style>
