{
  "name": "bi-report",
  "version": "0.2.0",
  "description": "简易 BI 报表 - 连 MySQL 出图表 + 保存查询 + 多图仪表盘",
  "main": "main.js",
  "author": "xrlnewman",
  "license": "MIT",
  "scripts": { "start": "electron .", "build": "electron-builder --win --x64" },
  "dependencies": {
    "chart.js": "^4.4.4",
    "mysql2": "^3.11.4",
    "xlsx": "https://cdn.sheetjs.com/xlsx-0.20.3/xlsx-0.20.3.tgz"
  },
  "devDependencies": { "electron": "^43.1.0", "electron-builder": "^26.15.3" },
  "build": {
    "appId": "com.xrlnewman.bi-report",
    "productName": "BIReport",
    "files": ["main.js", "preload.js", "lib/**/*", "renderer/**/*", "node_modules/**/*"],
    "win": { "target": [{ "target": "nsis", "arch": ["x64"] }] },
    "nsis": { "oneClick": false, "allowToChangeInstallationDirectory": true, "perMachine": false, "createDesktopShortcut": true, "shortcutName": "BIReport" }
  }
}
