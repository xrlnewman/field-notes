{
  "name": "db-snapshot-diff",
  "version": "0.2.0",
  "description": "数据库快照对比 - MySQL/PG 结构 + 数据采样 diff + 自动生成迁移 SQL (DDL)",
  "main": "main.js",
  "author": "xrlnewman",
  "license": "MIT",
  "scripts": { "start": "electron .", "build": "electron-builder --win --x64" },
  "dependencies": {
    "mysql2": "^3.11.4",
    "pg": "^8.13.1"
  },
  "devDependencies": { "electron": "^43.1.0", "electron-builder": "^26.15.3" },
  "build": {
    "appId": "com.xrlnewman.db-snapshot-diff",
    "productName": "DBSnapshotDiff",
    "files": ["main.js", "preload.js", "lib/**/*", "renderer/**/*", "node_modules/**/*"],
    "win": { "target": [{ "target": "nsis", "arch": ["x64"] }] },
    "nsis": { "oneClick": false, "allowToChangeInstallationDirectory": true, "perMachine": false, "createDesktopShortcut": true, "shortcutName": "DBSnapshotDiff" }
  }
}
