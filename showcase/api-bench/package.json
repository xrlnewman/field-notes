{
  "name": "api-bench",
  "version": "0.2.0",
  "description": "API 压测小工具 - 单接口/多步场景/预热/QPS/P99/保存压测计划",
  "main": "main.js",
  "author": "xrlnewman",
  "license": "MIT",
  "scripts": { "start": "electron .", "build": "electron-builder --win --x64" },
  "dependencies": { "chart.js": "^4.4.4" },
  "devDependencies": { "electron": "^43.1.0", "electron-builder": "^26.15.3" },
  "build": {
    "appId": "com.xrlnewman.api-bench",
    "productName": "ApiBench",
    "files": ["main.js", "preload.js", "renderer/**/*", "node_modules/**/*"],
    "win": { "target": [{ "target": "nsis", "arch": ["x64"] }] },
    "nsis": { "oneClick": false, "allowToChangeInstallationDirectory": true, "perMachine": false, "createDesktopShortcut": true, "shortcutName": "ApiBench" }
  }
}
